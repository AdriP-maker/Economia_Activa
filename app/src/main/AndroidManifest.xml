<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/logo_carrito"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/logo_carrito_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Economia_Activa">
        <activity
            android:name=".Home"
            android:exported="true"
            android:theme="@style/Theme.Economia_Activa">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".MainActivity" />
        <activity android:name=".ui.setup.TermsActivity" />
        <activity android:name=".ui.setup.SetupActivity" />
        <activity android:name=".ui.setup.BiometricLoginActivity" />
        <activity android:name=".ui.shopping.ShoppingListsActivity" />
        <activity android:name=".ui.shopping.ShoppingListDetailActivity" />
        <activity
            android:name=".ui.shopping.CustomScannerActivity"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:windowSoftInputMode="stateAlwaysHidden" />
        <activity android:name=".ui.expenses.ExpensesActivity" />
        <activity android:name=".ui.reports.ReportsActivity" />
        <activity android:name=".ui.tips.SavingsTipsActivity" />
    </application>

</manifest>