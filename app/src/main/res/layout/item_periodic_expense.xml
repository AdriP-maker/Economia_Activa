<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/colorCardBackground"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorOutlineVariant"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
    >

        <!-- Service Icon Container (blue for fixed services) -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_container_blue"
    >

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_wallet"
                android:contentDescription="@string/auto_str_servicio"
                app:tint="@color/colorSecondary" />
        </FrameLayout
    >

        <!-- Info -->
        <LinearLayout
            android:id="@+id/lyInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
    >

            <TextView
                android:id="@+id/tvConcept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_str_concepto_del_servicio"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/auto_str_d_a_de_pago_15_catego"
                android:textColor="@color/colorTextMuted"
                android:textSize="12sp" />
        </LinearLayout
    >

        <!-- Monto -->
        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            tools:text="$0.00"
            android:textColor="@color/colorSecondary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Botón editar en container -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_container_blue"
    >
            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@string/auto_str_editar_servicio"
                android:src="@drawable/ic_edit"
                app:tint="@color/colorSecondary" />
        </FrameLayout
    >

    </LinearLayout
    >
</androidx.cardview.widget.CardView
    >





