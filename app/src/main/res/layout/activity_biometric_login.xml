<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_biometric_gradient">

    <!-- ── Decorative floating circles ── -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="-80dp"
        android:background="@drawable/bg_glow_circle"
        android:alpha="0.12" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_glow_circle"
        android:alpha="0.08" />

    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="end|top"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="120dp"
        android:background="@drawable/bg_glow_circle"
        android:alpha="0.10" />

    <!-- ── Center Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Fingerprint Icon with glow ring -->
        <FrameLayout
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_marginBottom="32dp">

            <!-- Outer glow ring -->
            <View
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:background="@drawable/bg_fingerprint_glow"
                android:alpha="0.25" />

            <!-- Inner circle -->
            <View
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_fingerprint_inner"
                android:alpha="0.15" />

            <!-- Fingerprint icon -->
            <ImageView
                android:id="@+id/ivFingerprintIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:contentDescription="@string/auto_str_huella_dactilar"
                android:src="@drawable/ic_fingerprint"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/inter"
            android:text="@string/auto_str_acceso_seguro"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvBiometricGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="52dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:maxWidth="280dp"
            android:text="@string/auto_str_hola_por_favor_autent"
            android:textColor="@color/colorMint"
            android:textSize="14sp" />

        <!-- Unlock Button -->
        <Button
            android:id="@+id/btnUnlock"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:backgroundTint="@color/white"
            android:drawableStart="@drawable/ic_fingerprint"
            android:drawablePadding="8dp"
            android:drawableTint="@color/colorPrimary"
            android:fontFamily="@font/inter"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/auto_str_desbloquear"
            android:textColor="@color/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="26dp"
            app:elevation="0dp" />

    </LinearLayout>

    <!-- ── App version at bottom ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/inter"
        android:text="@string/auto_str_econom_a_activa_v2_0"
        android:textColor="#66FFFFFF"
        android:textSize="11sp" />

</FrameLayout>

