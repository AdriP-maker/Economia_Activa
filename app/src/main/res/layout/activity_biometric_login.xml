<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <ImageView
            android:id="@+id/ivFingerprintIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_fingerprint"
            app:tint="@color/white"
            android:contentDescription="Huella dactilar"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acceso Seguro"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvBiometricGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hola, por favor autentícate para ingresar"
            android:textColor="#E8F5E9"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/btnUnlock"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Desbloquear"
            android:backgroundTint="@color/white"
            android:textColor="@color/colorPrimary"
            android:textStyle="bold" />

    </LinearLayout>

</RelativeLayout>
