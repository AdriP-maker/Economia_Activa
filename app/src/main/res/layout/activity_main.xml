<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:paddingTop="28dp"
        android:background="@drawable/bg_header_gradient">

        <!-- Decorative overlay circles -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="-40dp"
            android:layout_marginEnd="-60dp"
            android:background="@drawable/bg_circle_overlay"
            android:alpha="0.15" />

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="start|bottom"
            android:layout_marginStart="-30dp"
            android:layout_marginBottom="-30dp"
            android:background="@drawable/bg_circle_overlay"
            android:alpha="0.10" />

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="36dp"
            android:fontFamily="@font/inter"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- App Motto -->
        <TextView
            android:id="@+id/tvAppMotto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="72dp"
            android:fontFamily="@font/inter"
            android:text="@string/app_motto"
            android:textColor="@color/white"
            android:alpha="0.9"
            android:textSize="13sp" />

        <!-- Settings Button -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_icon_button_white"
            android:contentDescription="@string/cd_configuracion"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/white" />

    </FrameLayout>

    <!-- ════════════════════════════════════════
         SCROLLABLE CONTENT
         ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="220dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Financial Summary Card (overlaps header) ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/colorCardBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Card Header Row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/inter"
                            android:text="@string/resumen_financiero"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/btnEditBudget"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_edit_button"
                            android:clickable="true"
                            android:contentDescription="@string/cd_editar_presupuesto"
                            android:focusable="true"
                            android:padding="14dp"
                            android:src="@drawable/ic_edit"
                            app:tint="@color/colorPrimary" />
                    </RelativeLayout>

                    <!-- Three Metrics Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- Presupuesto -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:letterSpacing="0.05"
                                android:text="@string/presupuesto_mensual"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextMuted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvBudgetVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter"
                                tools:text="$0.00"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="19sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@color/colorOutlineVariant" />

                        <!-- Gastado -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:letterSpacing="0.05"
                                android:text="@string/total_gastado"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextMuted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvSpentVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter"
                                tools:text="$0.00"
                                android:textColor="@color/colorDanger"
                                android:textSize="19sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@color/colorOutlineVariant" />

                        <!-- Disponible -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:letterSpacing="0.05"
                                android:text="@string/balance_disponible"
                                android:textAllCaps="true"
                                android:textColor="@color/colorTextMuted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvRemainingVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter"
                                tools:text="$0.00"
                                android:textColor="@color/colorPrimary"
                                android:textSize="19sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/budgetProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/colorSurfaceContainer"
                        android:progressTint="@color/colorPrimary" />

                    <!-- Percentage label -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:fontFamily="@font/inter"
                            android:text="@string/progreso_del_mes"
                            android:textColor="@color/colorTextMuted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvPercentageSpent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/inter"
                            tools:text="0% usado"
                            android:textColor="@color/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Modules Section Title ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/inter"
                android:text="@string/modulos_sistema"
                android:textColor="@color/colorTextPrimary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- ── 2x2 Module Grid ── -->
            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                app:columnCount="2"
                app:rowCount="2"
                app:useDefaultMargins="false">

                <!-- ─ Card 1: Organizar Compras ─ -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardShopping"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/colorCardBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:strokeColor="@color/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Icon Container -->
                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_icon_container_green">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_compras"
                                android:src="@drawable/ic_cart"
                                app:tint="@color/colorPrimary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/title_compras"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/desc_compras"
                            android:textColor="@color/colorTextMuted"
                            android:textSize="11sp" />

                        <!-- Arrow Row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_alignParentEnd="true"
                                android:contentDescription="@string/cd_ir"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/colorPrimary" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─ Card 2: Control de Gastos ─ -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExpenses"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/colorCardBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:strokeColor="@color/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_icon_container_blue">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_gastos"
                                android:src="@drawable/ic_wallet"
                                app:tint="@color/colorSecondary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/title_gastos"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/desc_gastos"
                            android:textColor="@color/colorTextMuted"
                            android:textSize="11sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_alignParentEnd="true"
                                android:contentDescription="@string/cd_ir"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/colorSecondary" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─ Card 3: Análisis de Hábitos ─ -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardReports"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/colorCardBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:strokeColor="@color/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_icon_container_amber">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_analisis"
                                android:src="@drawable/ic_chart"
                                app:tint="@color/colorTertiary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/title_analisis"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/desc_analisis"
                            android:textColor="@color/colorTextMuted"
                            android:textSize="11sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_alignParentEnd="true"
                                android:contentDescription="@string/cd_ir"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/colorTertiary" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ─ Card 4: Ahorro Inteligente ─ -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTips"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/colorCardBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:layout_columnWeight="1"
                    app:strokeColor="@color/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_icon_container_pink">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_ahorro"
                                android:src="@drawable/ic_tips"
                                app:tint="@color/colorAccentPink" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/title_ahorro"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter"
                            android:text="@string/desc_ahorro"
                            android:textColor="@color/colorTextMuted"
                            android:textSize="11sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_alignParentEnd="true"
                                android:contentDescription="@string/cd_ir"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/colorAccentPink" />
                        </RelativeLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </androidx.gridlayout.widget.GridLayout>

            <!-- Bottom padding spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>



    <!-- ════════════════════════════════════════
         SCROLLABLE CONTENT
         ════════════════════════════════════════ -->

</androidx.coordinatorlayout.widget.CoordinatorLayout>