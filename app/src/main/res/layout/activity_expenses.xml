<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    >

    <!-- ════ TOOLBAR ════ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/colorSurface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
    >

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/auto_str_regresar"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="@color/colorTextPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/inter"
            android:paddingStart="4dp"
            android:text="@string/auto_str_control_de_gastos"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout
    >

    <!-- ════ TAB BAR (Pill Style) ════ -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorSurface"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
    >

        <!-- Gastos Diarios Tab (ACTIVE) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTabDaily"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_tab_active"
            android:fontFamily="@font/inter"
            android:text="@string/auto_str_gastos_diarios"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <!-- Servicios Fijos Tab (INACTIVE) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTabFixed"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_tab_inactive"
            android:fontFamily="@font/inter"
            android:text="@string/auto_str_servicios_fijos"
            android:textColor="@color/colorTextMuted"
            android:textSize="13sp"
            android:textAllCaps="false" />

    </LinearLayout
    >

    <!-- ════ CONTENT ════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
    >

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
    >

            <!-- ─ VISTA 1: Gastos Diarios ─ -->
            <LinearLayout
                android:id="@+id/layoutDailyExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
    >

                <!-- Add Expense Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/colorCardBackground"
                    app:strokeColor="@color/colorOutlineVariant"
                    app:strokeWidth="1dp"
    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
    >

                        <!-- Card Header -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/auto_str_registrar_nuevo_gasto"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- Concept Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="@color/colorPrimary"
                            app:hintTextColor="@color/colorPrimary"
                            android:hint="Concepto (ej. Almuerzo, Uber, Farmacia)"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
    >

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDailyConcept"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:inputType="textCapSentences"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout
    >

                        <!-- Amount + Category Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp"
                            android:weightSum="2"
    >

                            <!-- Amount -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="@color/colorPrimary"
                                app:hintTextColor="@color/colorPrimary"
                                app:prefixText="$"
                                app:prefixTextColor="@color/colorPrimary"
                                android:hint="Monto"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
    >

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etDailyAmount"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:inputType="numberDecimal"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout
    >

                            <!-- Category Spinner Container -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="@color/colorPrimary"
                                app:hintTextColor="@color/colorPrimary"
                                android:hint="Categoría"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
    >

                                <AutoCompleteTextView
                                    android:id="@+id/spinnerDailyCategory"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/colorTextPrimary" />
                            </com.google.android.material.textfield.TextInputLayout
    >

                        </LinearLayout
    >

                        <!-- Add Button -->
                        <Button
                            android:id="@+id/btnSaveDailyExpense"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            app:backgroundTint="@null"
                            android:fontFamily="@font/inter"
                            android:text="@string/auto_str_agregar_gasto"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp" />

                    </LinearLayout
    >
                </androidx.cardview.widget.CardView
    >

                <!-- History Title Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
    >

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/auto_str_historial_reciente"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- Badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_badge_mint"
                            android:fontFamily="@font/inter"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            tools:text="0"
                            android:id="@+id/tvHistoryCount"
                            android:textColor="@color/colorPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout
    >
                </RelativeLayout
    >

                <!-- RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvExpensesHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/layoutDailyEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp"
                    android:visibility="gone"
    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_str"
                        android:textSize="48sp" />

                    <TextView
                        android:id="@+id/tvDailyEmpty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:text="@string/auto_str_no_hay_gastos_registr"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:text="@string/auto_str_agrega_tu_primer_gast"
                        android:textColor="@color/colorTextMuted"
                        android:textSize="12sp" />
                </LinearLayout
    >

            </LinearLayout
    >

            <!-- ─ VISTA 2: Servicios Fijos ─ -->
            <LinearLayout
                android:id="@+id/layoutFixedExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
    >

                <!-- Add Fixed Expense Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/colorCardBackground"
                    app:strokeColor="@color/colorOutlineVariant"
                    app:strokeWidth="1dp"
    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
    >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="@string/auto_str_registrar_servicio_re"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- Service Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="@color/colorSecondary"
                            app:hintTextColor="@color/colorSecondary"
                            android:hint="Nombre del Servicio (ej. Alquiler, Wifi)"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
    >

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFixedConcept"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:inputType="textCapSentences"
                                android:textColor="@color/colorTextPrimary"
                                android:textSize="14sp" />
                        </com.google.android.material.textfield.TextInputLayout
    >

                        <!-- Amount + Day + Category -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp"
                            android:weightSum="3"
    >

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="@color/colorSecondary"
                                app:prefixText="$"
                                app:prefixTextColor="@color/colorSecondary"
                                android:hint="Monto"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
    >

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etFixedAmount"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:inputType="numberDecimal"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout
    >

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="@color/colorSecondary"
                                android:hint="Día pago"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
    >

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etFixedDay"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:inputType="number"
                                    android:textColor="@color/colorTextPrimary"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout
    >

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="@color/colorSecondary"
                                android:hint="Categoría"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
    >

                                <AutoCompleteTextView
                                    android:id="@+id/spinnerFixedCategory"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/colorTextPrimary" />
                            </com.google.android.material.textfield.TextInputLayout
    >

                        </LinearLayout
    >

                        <!-- Register Button -->
                        <Button
                            android:id="@+id/btnSaveFixedExpense"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:backgroundTint="@color/colorSecondary"
                            android:fontFamily="@font/inter"
                            android:text="@string/auto_str_registrar_servicio"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp" />

                    </LinearLayout
    >
                </androidx.cardview.widget.CardView
    >

                <!-- Fixed Services Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/auto_str_servicios_activos"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPeriodicExpenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvFixedEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:text="@string/auto_str_no_hay_servicios_fijo"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

            </LinearLayout
    >

        </FrameLayout
    >
    </androidx.core.widget.NestedScrollView
    >

</LinearLayout
    >





