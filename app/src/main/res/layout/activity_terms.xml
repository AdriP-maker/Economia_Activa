<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    >

    <!-- ════ HEADER ════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingBottom="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@color/colorBackground"
    >

        <!-- Shield Icon -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_icon_container_green"
    >

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:contentDescription="@string/auto_str_seguridad"
                android:src="@drawable/ic_fingerprint"
                app:tint="@color/colorPrimary" />
        </FrameLayout
    >

        <TextView
            android:id="@+id/tvTermsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="@string/auto_str_t_rminos_y_condicione"
            android:textColor="@color/colorTextPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="@string/auto_str_aviso_legal_y_de_priv"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />
    </LinearLayout
    >

    <!-- ════ SCROLLABLE CONTENT ════ -->
    <ScrollView
        android:id="@+id/svTerms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
    >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/colorCardBackground"
            app:strokeColor="@color/colorOutlineVariant"
            app:strokeWidth="1dp"
    >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
    >

                <!-- Intro text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/auto_str_bienvenido_a_econom_a_1"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="20dp" />

                <!-- Section 1 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorSurfaceContainer"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_section_number"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:padding="4dp"
                        tools:text="1"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="@string/auto_str_prop_sito_de_la_aplic"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout
    >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/auto_str_econom_a_activa_es_un"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="20dp" />

                <!-- Section 2 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorSurfaceContainer"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_section_number"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:padding="4dp"
                        tools:text="2"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="@string/auto_str_almacenamiento_local"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout
    >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/auto_str_todos_los_datos_inclu"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="20dp" />

                <!-- Section 3 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorSurfaceContainer"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_section_number"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:padding="4dp"
                        tools:text="3"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="@string/auto_str_responsabilidad_del_u"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout
    >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/auto_str_usted_es_el_nico_resp"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="20dp" />

                <!-- Section 4 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorSurfaceContainer"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_section_number"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:padding="4dp"
                        tools:text="4"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="@string/auto_str_modificaciones"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout
    >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="@string/auto_str_los_desarrolladores_d"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="8dp" />

            </LinearLayout
    >
        </androidx.cardview.widget.CardView
    >

    </ScrollView
    >

    <!-- ════ BOTTOM FIXED AREA ════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorBackground"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="24dp"
    >

        <!-- Accept Checkbox -->
        <CheckBox
            android:id="@+id/chkAcceptTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="@color/colorPrimary"
            android:fontFamily="@font/inter"
            android:layout_marginBottom="16dp"
            android:text="@string/auto_str_he_le_do_y_acepto_los"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
    >

            <!-- Rechazar -->
            <Button
                android:id="@+id/btnDeclineTerms"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:fontFamily="@font/inter"
                android:text="@string/auto_str_rechazar"
                android:textColor="@color/colorDanger"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/colorDangerContainer"
                app:cornerRadius="16dp"
                app:strokeColor="@color/colorDanger"
                app:strokeWidth="0dp" />

            <!-- Aceptar -->
            <Button
                android:id="@+id/btnAcceptTerms"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_button_primary_gradient"
                android:enabled="false"
                android:fontFamily="@font/inter"
                android:text="@string/auto_str_aceptar"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

        </LinearLayout
    >

    </LinearLayout
    >

</LinearLayout
    >





