<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="20dp">

    <!-- Title Header -->
    <TextView
        android:id="@+id/tvTermsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Términos y Condiciones"
        android:textColor="@color/colorTextPrimary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_alignParentTop="true"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Scrollable Terms Content -->
    <ScrollView
        android:id="@+id/svTerms"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvTermsTitle"
        android:layout_above="@+id/chkAcceptTerms"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aviso Legal y de Privacidad"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bienvenido a Economía Activa. Al utilizar esta aplicación móvil, usted acepta de forma incondicional cumplir con los siguientes términos y condiciones de uso:"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Propósito de la Aplicación"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Economía Activa es una herramienta de uso personal diseñada para ayudar en el registro de productos de mercado, control de gastos diarios y sugerencias de ahorro familiar. No representa asesoramiento financiero profesional ni vinculante."
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Almacenamiento Local de Datos"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Todos los datos, incluyendo presupuestos, sueldos, nombres de usuario, historial de gastos y códigos de barras escaneados, se almacenan localmente en la base de datos interna de su dispositivo móvil. La aplicación no transmite ni recopila sus datos en servidores externos de terceros."
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Responsabilidad del Usuario"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Usted es el único responsable de la seguridad de su dispositivo y de la veracidad de los datos que ingresa. El uso de la función biométrica es opcional y depende del hardware y la configuración de seguridad de su propio sistema operativo."
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Modificaciones"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Los desarrolladores de Economía Activa se reservan el derecho de actualizar la aplicación, alterar las funcionalidades o modificar los términos legales en cualquier momento para cumplir con regulaciones locales de privacidad y optimización del software."
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Accept Checkbox -->
    <CheckBox
        android:id="@+id/chkAcceptTerms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="He leído y acepto los Términos y Condiciones"
        android:textColor="@color/colorTextPrimary"
        android:textSize="13sp"
        android:layout_above="@+id/layoutActionButtons"
        android:layout_marginBottom="12dp" />

    <!-- Button Actions (Horizontal Layout) -->
    <LinearLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentBottom="true"
        android:weightSum="2">

        <Button
            android:id="@+id/btnDeclineTerms"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Rechazar"
            android:backgroundTint="@color/colorDanger"
            android:textColor="@color/white"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnAcceptTerms"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Aceptar"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:layout_marginStart="6dp"
            android:enabled="false" />
    </LinearLayout>

</RelativeLayout>
