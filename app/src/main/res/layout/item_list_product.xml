<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/colorCardBackground"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorOutlineVariant"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
    >

        <!-- Checkbox / Estado -->
        <ImageView
            android:id="@+id/btnCheckItem"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="14dp"
            android:contentDescription="@string/auto_str_marcar_comprado"
            android:src="@drawable/ic_checkbox_unchecked"
            app:tint="@color/colorPrimary" />

        <!-- Info del Producto -->
        <LinearLayout
            android:id="@+id/lyProductInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp"
    >

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_str_nombre_del_producto"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/auto_str_categor_a_cantidad_x"
                android:textColor="@color/colorTextMuted"
                android:textSize="12sp" />
        </LinearLayout
    >

        <!-- Total del Item -->
        <TextView
            android:id="@+id/tvItemTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            tools:text="$0.00"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Botón editar -->
        <ImageView
            android:id="@+id/btnEditItem"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/auto_str_editar_producto"
            android:src="@drawable/ic_edit"
            app:tint="@color/colorTextMuted" />

        <!-- Botón eliminar -->
        <ImageView
            android:id="@+id/btnDeleteItem"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/auto_str_eliminar_producto"
            android:src="@drawable/ic_delete"
            app:tint="@color/colorDanger" />

    </LinearLayout
    >
</androidx.cardview.widget.CardView
    >





